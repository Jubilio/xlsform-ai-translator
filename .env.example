# Provedor utilizado quando o painel envia provider=auto.
# Valores: openai, deepl, microsoft, mock
TRANSLATION_PROVIDER=mock

# Servidor local
PORT=3001
MAX_BATCH_ITEMS=40
MAX_TEXT_LENGTH=5000

# OpenAI — a chave fica apenas no backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepL
DEEPL_API_KEY=6e58f9a8-3252-449e-817c-5670fb087450:fx
# Use api-free.deepl.com para plano Free e api.deepl.com para Pro.
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Microsoft Translator (Azure AI Translator)
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
