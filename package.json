{
  "name": "xlsform-ai-translator",
  "version": "1.0.0",
  "private": true,
  "description": "Office Add-in para traduzir questionários Kobo/XLSForm sem alterar códigos, fórmulas ou placeholders.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n SERVER,ADDIN -c auto \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "webpack serve --mode development",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "build:client": "webpack --mode production",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "certs": "tsx scripts/generate-cert.ts",
    "validate:manifest": "npx --yes office-addin-manifest validate manifest.xml",
    "sideload": "npx --yes office-addin-debugging start manifest.xml desktop",
    "stop": "npx --yes office-addin-debugging stop manifest.xml",
    "start:server": "node dist-server/server/index.js",
    "trust:cert:windows": "powershell -ExecutionPolicy Bypass -File scripts/trust-cert-windows.ps1"
  },
  "dependencies": {
    "deepl-node": "^1.27.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/office-js": "^1.0.500",
    "concurrently": "^9.2.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.3",
    "selfsigned": "^3.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "webpack": "^5.99.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.2.0"
  }
}
